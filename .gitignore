!checkpoints/**/.gitkeep
!checkpoints/**/*.json
!checkpoints/**/*.yaml
!checkpoints/**/*.yml

# Logs
logs/*.log
logs/*.json
*.log

# Data files (large datasets)
data/**/*.json
data/**/*.jsonl
data/**/*.csv
data/**/*.parquet
data/**/*.pkl
data/**/*.pickle
data/**/*.pt
data/**/*.pth
data/**/*.npy
data/**/*.npz
# Keep data directory structure and scripts
!data/**/.gitkeep
!data/**/*.py
!data/**/*.md

# Results (may contain large files)
results/**/*.pt
results/**/*.pth
results/**/*.bin
results/**/*.pkl
results/**/*.pickle
# Keep result summaries
!results/**/*.json
!results/**/*.csv
!results/**/*.txt
!results/**/*.md

# Experiments outputs
experiments/**/*.pt
experiments/**/*.pth
experiments/**/*.bin
experiments/**/*.safetensors
# Keep experiment configs
